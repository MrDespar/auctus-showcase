# AUCTUS Capital Partners AG — Environment Variables Template
# Copy to .env and populate with real values.
# NEVER commit .env to git — it is in .gitignore.

# ── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY_HERE

# ── Web Research (Brave Search MCP) ─────────────────────────────────────────
BRAVE_API_KEY=YOUR_BRAVE_SEARCH_KEY_HERE

# ── Financial Data — FactSet (optional; falls back to local CSVs) ────────────
FACTSET_API_KEY=YOUR_FACTSET_KEY_HERE
FACTSET_USERNAME=your.name@auctus.com
FACTSET_MCP_ENDPOINT=https://mcp.factset.com/v1

# ── Web Scraping — Browserbase (optional) ────────────────────────────────────
BROWSERBASE_API_KEY=YOUR_BROWSERBASE_KEY_HERE
BROWSERBASE_PROJECT_ID=YOUR_PROJECT_ID_HERE

# ── n8n Orchestration (cloud deployment only) ───────────────────────────────
N8N_USER=admin
N8N_PASSWORD=CHANGEME_STRONG_PASSWORD

# ── PostgreSQL (cloud deployment only) ──────────────────────────────────────
POSTGRES_PASSWORD=CHANGEME_STRONG_PASSWORD

# ── Application ─────────────────────────────────────────────────────────────
AUCTUS_ENV=development
PROJECT_ROOT=/Users/maxpescosta/Desktop/LLM Projects/auctus_showcase
